# Credenziali di firma per la release (Google Play).
# Copia questo file in `keystore.properties` (NON versionato) e compila i valori.
#
#   cp keystore.properties.example keystore.properties
#
# storeFile: percorso del keystore, relativo alla radice del progetto.
storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
